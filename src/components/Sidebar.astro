---
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const blogs    = await getCollection('blog');

// Sort projects newest-first
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname.replace(/\/$/, '') || '/';

function active(href: string) {
  const clean = href.replace(/\/$/, '');
  return path === clean || path.startsWith(clean + '/');
}

const homeHref = base || '/';
---

<!-- Left sidebar — fixed, slides in on mobile -->
<aside
  id="sidebar"
  class="fixed left-0 top-0 h-screen w-[260px] flex flex-col
         bg-[#09090F] border-r border-white/[0.07] z-40
         -translate-x-full lg:translate-x-0 transition-transform duration-300
         overflow-y-auto"
>
  <!-- ── Brand ── -->
  <div class="px-5 pt-6 pb-5 border-b border-white/[0.05] shrink-0">
    <a href={homeHref} class="flex items-center gap-3 group cursor-pointer">
      <!-- Icon mark -->
      <div class="w-9 h-9 rounded-xl bg-cyan-500/10 border border-cyan-500/25 flex items-center justify-center shrink-0
                  group-hover:bg-cyan-500/20 group-hover:border-cyan-500/50 transition-all duration-200">
        <svg class="w-4 h-4 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1 1 .03 2.798-1.32 2.798H4.118c-1.348 0-2.318-1.798-1.319-2.798L4 15.299" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-white leading-snug">Mohamed Abdelaziz</p>
        <p class="text-[11px] text-cyan-400/70 font-mono tracking-tight">Medical AI Engineer</p>
      </div>
    </a>
  </div>

  <!-- ── Nav ── -->
  <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

    <!-- Home -->
    <a href={homeHref}
       class={`flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-all duration-150 cursor-pointer border-l-2 w-full
               ${active(homeHref) && path === (base || '/')
                 ? 'nav-active font-medium'
                 : 'border-transparent text-gray-400 hover:text-gray-200 hover:bg-white/[0.04]'}`}>
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
      </svg>
      Home
    </a>

    <!-- ── Projects section ── -->
    <div class="pt-3">
      <a href={`${base}/projects`}
         class={`flex items-center gap-2 px-3 pb-1.5 text-[11px] font-semibold uppercase tracking-widest
                 transition-colors duration-150 cursor-pointer
                 ${active(`${base}/projects`)
                   ? 'text-cyan-400'
                   : 'text-gray-600 hover:text-gray-400'}`}>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776"/>
        </svg>
        Projects
      </a>

      {projects.map((p) => {
        const href   = `${base}/projects/${p.id}`;
        const isAct  = active(href);
        const client = p.data.client ?? '';

        const dotColor =
          client === 'MedSoft'            ? 'bg-cyan-400'   :
          client === 'Ramyro'             ? 'bg-violet-400' :
          client === 'Toronto-Pittsburgh' ? 'bg-orange-400' :
          'bg-gray-600';

        return (
          <a href={href}
             class={`flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] transition-all duration-150 cursor-pointer border-l-2
                     ${isAct
                       ? 'nav-active font-medium'
                       : 'border-transparent text-gray-400 hover:text-gray-200 hover:bg-white/[0.04]'}`}>
            <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${isAct ? 'bg-cyan-400' : dotColor} opacity-60`}></span>
            <span class="truncate leading-tight">{p.data.title}</span>
            {p.data.client && (
              <span class="ml-auto text-[10px] px-1.5 py-0.5 rounded bg-white/[0.05] text-gray-600 shrink-0 font-mono">
                {p.data.client}
              </span>
            )}
          </a>
        );
      })}
    </div>

    <!-- ── Blog section ── -->
    <div class="pt-3">
      <a href={`${base}/blog`}
         class={`flex items-center gap-2 px-3 pb-1.5 text-[11px] font-semibold uppercase tracking-widest
                 transition-colors duration-150 cursor-pointer
                 ${active(`${base}/blog`)
                   ? 'text-cyan-400'
                   : 'text-gray-600 hover:text-gray-400'}`}>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
        </svg>
        Blog
      </a>

      {blogs.length === 0 ? (
        <p class="px-3 py-1.5 text-[12px] text-gray-700 italic">No posts yet</p>
      ) : blogs.map((post) => {
        const href  = `${base}/blog/${post.id}`;
        const isAct = active(href);
        return (
          <a href={href}
             class={`flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] transition-all duration-150 cursor-pointer border-l-2
                     ${isAct
                       ? 'nav-active font-medium'
                       : 'border-transparent text-gray-400 hover:text-gray-200 hover:bg-white/[0.04]'}`}>
            <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${isAct ? 'bg-cyan-400' : 'bg-gray-700'}`}></span>
            <span class="truncate leading-tight">{post.data.title}</span>
          </a>
        );
      })}
    </div>

  </nav>

  <!-- ── Social footer ── -->
  <div class="px-5 py-4 border-t border-white/[0.05] shrink-0">
    <div class="flex items-center gap-4">
      <a href="https://github.com/mohamed-abdelaziz721" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-1.5 text-[12px] text-gray-600 hover:text-gray-300 transition-colors cursor-pointer">
        <!-- GitHub icon -->
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/mohamed-abdelaziz721" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-1.5 text-[12px] text-gray-600 hover:text-gray-300 transition-colors cursor-pointer">
        <!-- LinkedIn icon -->
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>
  </div>
</aside>
