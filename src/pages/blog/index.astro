---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Blog — Mohamed Abdelaziz">

  <div class="mb-10 pb-6 border-b border-white/[0.07]">
    <p class="text-xs font-mono text-cyan-400/60 uppercase tracking-widest mb-2">Writing</p>
    <h1 class="text-3xl font-bold text-white mb-2">Blog</h1>
    <p class="text-gray-500 text-sm max-w-lg">
      Deep-dives into medical imaging, AI pipelines, 3D geometry, and clinical software engineering.
    </p>
  </div>

  {posts.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-24 border border-dashed border-white/[0.08] rounded-2xl">
      <svg class="w-8 h-8 text-gray-700 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
      </svg>
      <p class="text-gray-600 text-sm mb-1">No posts yet</p>
      <p class="text-gray-700 text-xs">
        Drop an <code class="text-gray-500">.mdx</code> file in <code class="text-gray-500">src/content/blog/</code>
      </p>
    </div>
  ) : (
    <div class="grid gap-4">
      {posts.map((post, i) => {
        const dateStr = post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        return (
          <a
            href={`${base}/blog/${post.id}`}
            class="group flex items-start gap-5 border border-white/[0.07] hover:border-cyan-500/30
                   rounded-2xl p-6 transition-all duration-300 cursor-pointer
                   bg-gradient-to-br from-white/[0.02] to-transparent hover:from-cyan-500/[0.04]
                   card-animate"
            style={`animation-delay: ${i * 70}ms`}
          >
            <!-- Date column -->
            <div class="shrink-0 text-center min-w-[52px]">
              <p class="text-lg font-bold text-gray-300 tabular-nums leading-none">
                {post.data.date.getDate().toString().padStart(2, '0')}
              </p>
              <p class="text-[10px] text-gray-600 uppercase tracking-wider mt-0.5">
                {post.data.date.toLocaleDateString('en-US', { month: 'short' })}
              </p>
              <p class="text-[10px] text-gray-700 mt-0.5">
                {post.data.date.getFullYear()}
              </p>
            </div>

            <!-- Divider -->
            <div class="w-px self-stretch bg-white/[0.06] shrink-0"/>

            <!-- Content -->
            <div class="flex-1 min-w-0">
              <h2 class="text-base font-semibold text-gray-200 group-hover:text-white transition-colors mb-1.5">
                {post.data.title}
              </h2>
              <p class="text-gray-500 text-sm leading-relaxed mb-3">
                {post.data.description}
              </p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag: string) => (
                    <span class="text-[11px] px-2 py-0.5 rounded-md bg-white/[0.05] text-gray-500 border border-white/[0.08]">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>

            <!-- Arrow -->
            <div class="self-center opacity-0 group-hover:opacity-100 transition-all duration-200
                        translate-x-2 group-hover:translate-x-0 shrink-0">
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/>
              </svg>
            </div>
          </a>
        );
      })}
    </div>
  )}
</BaseLayout>
