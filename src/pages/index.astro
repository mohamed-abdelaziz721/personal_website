---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroContent from '../components/HeroContent';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Tag chip colours — complete strings so Tailwind JIT can scan them
const tagColors: Record<string, string> = {
  'VTK':              'bg-blue-500/10   text-blue-400   border-blue-500/20',
  'PyQt5':            'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
  'Deep Learning':    'bg-violet-500/10 text-violet-400 border-violet-500/20',
  '3D Slicer':        'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'Mesh Processing':  'bg-sky-500/10    text-sky-400    border-sky-500/20',
  'Medical Imaging':  'bg-cyan-500/10   text-cyan-400   border-cyan-500/20',
  'FastAPI':          'bg-green-500/10  text-green-400  border-green-500/20',
  'DICOM':            'bg-teal-500/10   text-teal-400   border-teal-500/20',
  'Docker':           'bg-sky-500/10    text-sky-400    border-sky-500/20',
  'ONNX':             'bg-orange-500/10 text-orange-400 border-orange-500/20',
  'TensorRT':         'bg-amber-500/10  text-amber-400  border-amber-500/20',
  'Computer Vision':  'bg-pink-500/10   text-pink-400   border-pink-500/20',
  'Optical Flow':     'bg-rose-500/10   text-rose-400   border-rose-500/20',
  'Medical AI':       'bg-cyan-500/10   text-cyan-400   border-cyan-500/20',
};
const defaultTag = 'bg-white/[0.05] text-gray-500 border-white/[0.08]';

// Per-client card accent classes (complete strings for Tailwind scanner)
const clientCard: Record<string, { border: string; glow: string; badge: string }> = {
  'MedSoft': {
    border: 'hover:border-cyan-500/40',
    glow:   'group-hover:from-cyan-500/10',
    badge:  'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
  },
  'Ramyro': {
    border: 'hover:border-violet-500/40',
    glow:   'group-hover:from-violet-500/10',
    badge:  'text-violet-400 bg-violet-500/10 border-violet-500/20',
  },
  'Toronto-Pittsburgh': {
    border: 'hover:border-orange-500/40',
    glow:   'group-hover:from-orange-500/10',
    badge:  'text-orange-400 bg-orange-500/10 border-orange-500/20',
  },
};
const defaultCard = {
  border: 'hover:border-white/20',
  glow:   'group-hover:from-white/5',
  badge:  'text-gray-400 bg-white/5 border-white/10',
};

// Tech stack section
const techGroups = [
  {
    label: 'AI & Deep Learning',
    color: 'text-violet-400',
    items: ['TensorFlow / Keras', 'ONNX', 'TensorRT', 'SimpleITK', 'PyTorch'],
  },
  {
    label: '3D & Medical Imaging',
    color: 'text-cyan-400',
    items: ['VTK', '3D Slicer', 'ITK', 'Open3D', 'DICOM / PACS'],
  },
  {
    label: 'Backend & Infra',
    color: 'text-green-400',
    items: ['FastAPI', 'Docker', 'AWS', 'PyQt5', 'Python'],
  },
];
---

<BaseLayout title="Mohamed Abdelaziz — Medical AI & 3D Visualization">

  <!-- ── Hero (Framer Motion, client:load) ── -->
  <HeroContent client:load />

  <!-- ── Projects ── -->
  <section class="mb-20">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-100">Projects</h2>
      <a href={`${base}/projects`}
         class="text-sm text-gray-500 hover:text-cyan-400 transition-colors cursor-pointer">
        All projects →
      </a>
    </div>

    <div class="grid gap-4">
      {projects.map((p, i) => {
        const cc = clientCard[p.data.client ?? ''] ?? defaultCard;
        return (
          <a
            href={`${base}/projects/${p.id}`}
            class={`group relative block border border-white/[0.07] ${cc.border}
                    rounded-2xl p-6 transition-all duration-300 cursor-pointer overflow-hidden
                    bg-gradient-to-br from-white/[0.02] to-transparent card-animate`}
            style={`animation-delay: ${i * 80}ms`}
          >
            <!-- Hover glow -->
            <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${cc.glow} to-transparent
                         opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none`}/>

            <!-- Header -->
            <div class="relative flex items-start justify-between gap-4 mb-2">
              <h3 class="text-base font-semibold text-gray-200 group-hover:text-white transition-colors leading-snug">
                {p.data.title}
              </h3>
              {p.data.client && (
                <span class={`text-[11px] font-medium px-2 py-1 rounded-md border shrink-0 ${cc.badge}`}>
                  {p.data.client}
                </span>
              )}
            </div>

            <!-- Description -->
            <p class="relative text-gray-500 text-sm leading-relaxed mb-4">
              {p.data.description}
            </p>

            <!-- Tags -->
            <div class="relative flex flex-wrap gap-1.5">
              {(p.data.tags ?? []).map((tag: string) => (
                <span class={`text-[11px] px-2 py-0.5 rounded-md border ${tagColors[tag] ?? defaultTag}`}>
                  {tag}
                </span>
              ))}
            </div>

            <!-- Arrow -->
            <div class="absolute bottom-5 right-5 opacity-0 group-hover:opacity-100 transition-all duration-200
                        translate-x-1 group-hover:translate-x-0">
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25"/>
              </svg>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- ── Tech stack ── -->
  <section class="mb-20">
    <h2 class="text-xl font-bold text-gray-100 mb-6">Tech Stack</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      {techGroups.map((g) => (
        <div class="border border-white/[0.07] rounded-2xl p-5 bg-white/[0.01]">
          <p class={`text-[11px] font-semibold uppercase tracking-widest mb-3 ${g.color}`}>
            {g.label}
          </p>
          <ul class="space-y-1.5">
            {g.items.map((item) => (
              <li class="flex items-center gap-2 text-sm text-gray-400">
                <span class="w-1 h-1 rounded-full bg-current opacity-50 shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
