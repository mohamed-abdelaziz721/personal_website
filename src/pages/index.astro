---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mohamed Abdelaziz">
  <section class="py-16">
    <h1 class="text-4xl font-bold mb-4">Mohamed Abdelaziz</h1>
    <p class="text-xl text-gray-400 mb-8">
      Medical imaging · 3D visualization · Data science
    </p>
    <div class="flex gap-4 flex-wrap">
      <a href="/personal_website/projects" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-lg transition-colors">
        Projects
      </a>
      <a href="/personal_website/blog" class="px-4 py-2 border border-gray-700 hover:border-gray-500 rounded-lg transition-colors">
        Blog
      </a>
      <a href="https://github.com/mohamed-abdelaziz721" target="_blank" class="px-4 py-2 border border-gray-700 hover:border-gray-500 rounded-lg transition-colors">
        GitHub
      </a>
    </div>
  </section>
</BaseLayout>
