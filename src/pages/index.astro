---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagColors: Record<string, string> = {
  'VTK': 'bg-blue-900 text-blue-300',
  'Deep Learning': 'bg-purple-900 text-purple-300',
  '3D Slicer': 'bg-green-900 text-green-300',
  'FastAPI': 'bg-emerald-900 text-emerald-300',
  'DICOM': 'bg-cyan-900 text-cyan-300',
  'Docker': 'bg-sky-900 text-sky-300',
  'Computer Vision': 'bg-orange-900 text-orange-300',
};
const defaultTag = 'bg-gray-800 text-gray-400';
---

<BaseLayout title="Mohamed Abdelaziz — Medical Imaging & AI">
  <!-- Hero -->
  <section class="py-16 border-b border-gray-800 mb-16">
    <p class="text-blue-400 text-sm font-mono mb-3 tracking-widest uppercase">Medical Software Engineer</p>
    <h1 class="text-5xl font-bold mb-5 leading-tight">Mohamed Abdelaziz</h1>
    <p class="text-xl text-gray-400 mb-2 max-w-2xl">
      Building clinical AI and 3D visualization pipelines — CT segmentation, mesh processing,
      surgical planning, DICOM inference, fluoroscopy analysis.
    </p>
    <p class="text-gray-500 mb-8 max-w-2xl">
      Three production projects across craniomaxillofacial surgery, radiology AI, and swallowing analysis.
    </p>
    <div class="flex gap-3 flex-wrap">
      <a href="/personal_website/projects"
         class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 rounded-lg transition-colors font-medium">
        Projects
      </a>
      <a href="/personal_website/blog"
         class="px-5 py-2.5 border border-gray-700 hover:border-gray-500 rounded-lg transition-colors">
        Blog
      </a>
      <a href="https://github.com/mohamed-abdelaziz721" target="_blank"
         class="px-5 py-2.5 border border-gray-700 hover:border-gray-500 rounded-lg transition-colors">
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/mohamed-abdelaziz721" target="_blank"
         class="px-5 py-2.5 border border-gray-700 hover:border-gray-500 rounded-lg transition-colors">
        LinkedIn
      </a>
    </div>
  </section>

  <!-- Projects -->
  <section>
    <h2 class="text-2xl font-bold mb-8">Projects</h2>
    <div class="grid gap-6">
      {projects.map((p) => (
        <a href={`/personal_website/projects/${p.id}`}
           class="block border border-gray-800 hover:border-blue-600 rounded-xl p-6 transition-all hover:bg-gray-900">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="text-xl font-semibold">{p.data.title}</h3>
            {p.data.client && (
              <span class="text-xs text-gray-500 shrink-0 pt-1">
                {p.data.client}
              </span>
            )}
          </div>
          <p class="text-gray-400 text-sm mb-4">{p.data.description}</p>
          <div class="flex flex-wrap gap-2">
            {p.data.tags?.map((tag: string) => (
              <span class={`text-xs px-2 py-0.5 rounded ${tagColors[tag] ?? defaultTag}`}>
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
