---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { id: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);

const base    = import.meta.env.BASE_URL.replace(/\/$/, '');
const dateStr = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long',
});

const tagColors: Record<string, string> = {
  'VTK':              'bg-blue-500/10   text-blue-400   border-blue-500/20',
  'PyQt5':            'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
  'Deep Learning':    'bg-violet-500/10 text-violet-400 border-violet-500/20',
  '3D Slicer':        'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'Mesh Processing':  'bg-sky-500/10    text-sky-400    border-sky-500/20',
  'Medical Imaging':  'bg-cyan-500/10   text-cyan-400   border-cyan-500/20',
  'FastAPI':          'bg-green-500/10  text-green-400  border-green-500/20',
  'DICOM':            'bg-teal-500/10   text-teal-400   border-teal-500/20',
  'Docker':           'bg-sky-500/10    text-sky-400    border-sky-500/20',
  'ONNX':             'bg-orange-500/10 text-orange-400 border-orange-500/20',
  'TensorRT':         'bg-amber-500/10  text-amber-400  border-amber-500/20',
  'Computer Vision':  'bg-pink-500/10   text-pink-400   border-pink-500/20',
  'Optical Flow':     'bg-rose-500/10   text-rose-400   border-rose-500/20',
  'Medical AI':       'bg-cyan-500/10   text-cyan-400   border-cyan-500/20',
};
const defaultTag = 'bg-white/[0.05] text-gray-500 border-white/[0.08]';

const clientBadge: Record<string, string> = {
  'MedSoft':            'text-cyan-400   bg-cyan-500/10   border-cyan-500/25',
  'Ramyro':             'text-violet-400 bg-violet-500/10 border-violet-500/25',
  'Toronto-Pittsburgh': 'text-orange-400 bg-orange-500/10 border-orange-500/25',
};
---

<BaseLayout
  title={`${project.data.title} — Mohamed Abdelaziz`}
  description={project.data.description}
  headings={headings}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs text-gray-600 mb-8">
    <a href={`${base}/`}            class="hover:text-gray-400 transition-colors cursor-pointer">Home</a>
    <span>/</span>
    <a href={`${base}/projects`}    class="hover:text-gray-400 transition-colors cursor-pointer">Projects</a>
    <span>/</span>
    <span class="text-gray-400 truncate">{project.data.title}</span>
  </nav>

  <!-- Project header -->
  <header class="mb-10 pb-8 border-b border-white/[0.07]">
    <!-- Meta row -->
    <div class="flex flex-wrap items-center gap-3 mb-4">
      {project.data.client && (
        <span class={`text-[12px] font-medium px-2.5 py-1 rounded-lg border
                      ${clientBadge[project.data.client] ?? 'text-gray-400 bg-white/5 border-white/10'}`}>
          {project.data.client}
        </span>
      )}
      <span class="text-xs text-gray-600 font-mono">{dateStr}</span>
      {project.data.github && (
        <a href={project.data.github} target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-1.5 text-xs text-gray-500 hover:text-gray-300 transition-colors cursor-pointer">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          View on GitHub
        </a>
      )}
    </div>

    <h1 class="text-3xl font-bold text-white mb-3 leading-tight">
      {project.data.title}
    </h1>
    <p class="text-gray-400 text-base leading-relaxed max-w-2xl mb-5">
      {project.data.description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2">
      {(project.data.tags ?? []).map((tag: string) => (
        <span class={`text-[12px] px-2.5 py-1 rounded-lg border ${tagColors[tag] ?? defaultTag}`}>
          {tag}
        </span>
      ))}
    </div>
  </header>

  <!-- MDX body -->
  <article class="prose prose-lg max-w-none">
    <Content />
  </article>

  <!-- Footer nav -->
  <div class="mt-16 pt-6 border-t border-white/[0.07]">
    <a href={`${base}/projects`}
       class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-300 transition-colors cursor-pointer">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
      </svg>
      All projects
    </a>
  </div>
</BaseLayout>
