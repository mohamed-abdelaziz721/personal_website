---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tagColors: Record<string, string> = {
  'VTK':              'bg-blue-500/10   text-blue-400   border-blue-500/20',
  'PyQt5':            'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
  'Deep Learning':    'bg-violet-500/10 text-violet-400 border-violet-500/20',
  '3D Slicer':        'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'Mesh Processing':  'bg-sky-500/10    text-sky-400    border-sky-500/20',
  'Medical Imaging':  'bg-cyan-500/10   text-cyan-400   border-cyan-500/20',
  'FastAPI':          'bg-green-500/10  text-green-400  border-green-500/20',
  'DICOM':            'bg-teal-500/10   text-teal-400   border-teal-500/20',
  'Docker':           'bg-sky-500/10    text-sky-400    border-sky-500/20',
  'ONNX':             'bg-orange-500/10 text-orange-400 border-orange-500/20',
  'TensorRT':         'bg-amber-500/10  text-amber-400  border-amber-500/20',
  'Computer Vision':  'bg-pink-500/10   text-pink-400   border-pink-500/20',
  'Optical Flow':     'bg-rose-500/10   text-rose-400   border-rose-500/20',
  'Medical AI':       'bg-cyan-500/10   text-cyan-400   border-cyan-500/20',
};
const defaultTag = 'bg-white/[0.05] text-gray-500 border-white/[0.08]';

const clientCard: Record<string, { border: string; glow: string; badge: string; accent: string }> = {
  'MedSoft': {
    border: 'hover:border-cyan-500/40',
    glow:   'group-hover:from-cyan-500/10',
    badge:  'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
    accent: 'text-cyan-400',
  },
  'Ramyro': {
    border: 'hover:border-violet-500/40',
    glow:   'group-hover:from-violet-500/10',
    badge:  'text-violet-400 bg-violet-500/10 border-violet-500/20',
    accent: 'text-violet-400',
  },
  'Toronto-Pittsburgh': {
    border: 'hover:border-orange-500/40',
    glow:   'group-hover:from-orange-500/10',
    badge:  'text-orange-400 bg-orange-500/10 border-orange-500/20',
    accent: 'text-orange-400',
  },
};
const defaultCard = {
  border: 'hover:border-white/20',
  glow:   'group-hover:from-white/5',
  badge:  'text-gray-400 bg-white/5 border-white/10',
  accent: 'text-gray-400',
};
---

<BaseLayout title="Projects — Mohamed Abdelaziz">

  <!-- Page header -->
  <div class="mb-10 pb-6 border-b border-white/[0.07]">
    <p class="text-xs font-mono text-cyan-400/60 uppercase tracking-widest mb-2">Portfolio</p>
    <h1 class="text-3xl font-bold text-white mb-2">Projects</h1>
    <p class="text-gray-500 text-sm max-w-lg">
      Production clinical AI and 3D visualization systems — built for surgery, radiology, and swallowing analysis.
    </p>
  </div>

  {projects.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-24 border border-dashed border-white/[0.08] rounded-2xl">
      <p class="text-gray-600 text-sm">No projects yet.</p>
      <p class="text-gray-700 text-xs mt-1">Drop an <code class="text-gray-500">.mdx</code> file in <code class="text-gray-500">src/content/projects/</code></p>
    </div>
  ) : (
    <div class="grid gap-5">
      {projects.map((p, i) => {
        const cc = clientCard[p.data.client ?? ''] ?? defaultCard;
        const dateStr = p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
        return (
          <a
            href={`${base}/projects/${p.id}`}
            class={`group relative flex gap-5 border border-white/[0.07] ${cc.border}
                    rounded-2xl p-6 transition-all duration-300 cursor-pointer overflow-hidden
                    bg-gradient-to-br from-white/[0.02] to-transparent card-animate`}
            style={`animation-delay: ${i * 70}ms`}
          >
            <!-- Glow -->
            <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${cc.glow} to-transparent
                         opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none`}/>

            <!-- Numbered index -->
            <div class={`relative shrink-0 w-10 h-10 rounded-xl border border-white/[0.08]
                         flex items-center justify-center text-sm font-bold tabular-nums ${cc.accent}
                         bg-white/[0.03] mt-0.5`}>
              {String(i + 1).padStart(2, '0')}
            </div>

            <!-- Content -->
            <div class="relative flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-1.5">
                <h2 class="text-base font-semibold text-gray-200 group-hover:text-white transition-colors">
                  {p.data.title}
                </h2>
                <div class="flex items-center gap-2 shrink-0">
                  {p.data.client && (
                    <span class={`text-[11px] font-medium px-2 py-0.5 rounded-md border ${cc.badge}`}>
                      {p.data.client}
                    </span>
                  )}
                  <span class="text-[11px] text-gray-700 font-mono">{dateStr}</span>
                </div>
              </div>
              <p class="text-gray-500 text-sm leading-relaxed mb-3">
                {p.data.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {(p.data.tags ?? []).map((tag: string) => (
                  <span class={`text-[11px] px-2 py-0.5 rounded-md border ${tagColors[tag] ?? defaultTag}`}>
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Arrow -->
            <div class="relative self-center opacity-0 group-hover:opacity-100 transition-all duration-200
                        translate-x-2 group-hover:translate-x-0 shrink-0">
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/>
              </svg>
            </div>
          </a>
        );
      })}
    </div>
  )}
</BaseLayout>
